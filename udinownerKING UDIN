--// LABEL
local function makeLabel(text)
    local t = Instance.new("TextLabel", Frame)
    t.Size = UDim2.new(1, 0, 0, 25)
    t.BackgroundTransparency = 1
    t.Text = text
    t.TextColor3 = Color3.fromRGB(255,60,60)
    t.Font = Enum.Font.GothamBold
    t.TextSize = 14
    t.TextXAlignment = Enum.TextXAlignment.Center
    return t
end

local Title = makeLabel("Private Mourch")
local KillText = makeLabel("Kill: 0")
local TimerText = makeLabel(hopDelay.."s")

--// KILL COUNTER
local function setupKillCounter()
    local stats = player:WaitForChild("leaderstats", 10)
    if not stats then return end

    local stat = stats:FindFirstChild("Kills")
        or stats:FindFirstChild("Kill")
        or stats:FindFirstChild("Eliminations")

    if not stat then return end

    KillText.Text = "Kill: "..stat.Value

    stat:GetPropertyChangedSignal("Value"):Connect(function()
        KillText.Text = "Kill: "..stat.Value
    end)
end

setupKillCounter()

--// SERVER HOP (ONLY ONE FUNCTION FIXED)
local function serverHop()
    local url = "https://games.roblox.com/v1/games/"..PlaceId.."/servers/Public?sortOrder=Desc&limit=100"

    local success, result = pcall(function()
        return HttpService:JSONDecode(game:HttpGet(url))
    end)

    if not success or not result or not result.data then return end

    local bestServer
    local highest = 0

    for _, server in pairs(result.data) do
        if server.id ~= game.JobId and server.playing < server.maxPlayers then
            if server.playing > highest then
                highest = server.playing
                bestServer = server
            end
        end
    end

    if bestServer then
        TeleportService:TeleportToPlaceInstance(PlaceId, bestServer.id, player)
    end
end

--// TIMER LOOP
task.spawn(function()
    local t = hopDelay

    while true do
        TimerText.Text = t.."s"
        task.wait(1)
        t -= 1

        if t <= 0 then
            serverHop()
            t = hopDelay
        end
    end
end)
